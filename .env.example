PUBLIC_CONVEX_URL=https://your-project.convex.cloud
PUBLIC_CONVEX_SITE_URL=https://your-project.convex.site
PUBLIC_SITE_URL=http://localhost:5173

BETTER_AUTH_URL=http://localhost:5173
BETTER_AUTH_SECRET=replace-with-random-secret
GOOGLE_CLIENT_ID=replace-with-google-oauth-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-oauth-client-secret

RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=replace-with-razorpay-secret
RAZORPAY_PRO_PLAN_ID=plan_xxx
RAZORPAY_WEBHOOK_SECRET=replace-with-razorpay-webhook-secret

FBS_BASE_URL=https://fbs.jr4.in
FBS_BUCKET=qckpages
FBS_PUBLIC_BASE_URL=https://fbs.jr4.in
FBS_PUBLIC_READ_TTL_SECONDS=3600
FBS_SIGV4_ACCESS_KEY_ID=replace-with-fbsv4-access-key
FBS_SIGV4_SECRET_KEY=replace-with-fbsv4-secret

# Optional: if available, QckPages will use FBS /public signed URLs instead of SigV4 presigned URLs.
FBS_PUBLIC_READ_SIGNING_SECRET=
