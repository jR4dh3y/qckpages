FBS_BASE_URL=https://fbs.jr4.in
FBS_BUCKET=qckpages
FBS_PUBLIC_BASE_URL=https://fbs.jr4.in
FBS_PUBLIC_READ_TTL_SECONDS=3600
FBS_SIGV4_ACCESS_KEY_ID=replace-with-fbsv4-access-key
FBS_SIGV4_SECRET_KEY=replace-with-fbsv4-secret

# Optional: if available, QckPages will use FBS /public signed URLs instead of SigV4 presigned URLs.
FBS_PUBLIC_READ_SIGNING_SECRET=

# Optional Shoo overrides. Defaults are https://shoo.dev.
SHOO_BASE_URL=https://shoo.dev
SHOO_ISSUER=https://shoo.dev

# Edge Config reads use EDGE_CONFIG when deployed on Vercel.
EDGE_CONFIG=https://edge-config.vercel.com/ecfg_xxx?token=xxx

# Edge Config writes use the Vercel REST API.
VERCEL_API_TOKEN=replace-with-vercel-access-token
VERCEL_EDGE_CONFIG_ID=ecfg_xxx
VERCEL_TEAM_ID=
VERCEL_TEAM_SLUG=
